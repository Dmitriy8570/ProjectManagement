# Copy to .env and tweak. docker-compose reads it automatically.

# ---- Host-side ports (left side of "host:container") ----
API_PORT=5266
WEB_PORT=5100
VUE_PORT=5173
MSSQL_PORT=1433

# ---- ASP.NET environment ----
ASPNETCORE_ENVIRONMENT=Production

# =====================================================================
# Database selection — uncomment ONE block.
# =====================================================================

# --- SQLite (default; no extra service required) -----------------------
DB_PROVIDER=Sqlite
DB_CONN_STR=Data Source=/data/projectmanagement.db

# --- MSSQL (requires `--profile mssql`) -------------------------------
# DB_PROVIDER=SqlServer
# DB_CONN_STR=Server=mssql,1433;Database=ProjectManagement;User Id=sa;Password=Your_password123!;TrustServerCertificate=True;Encrypt=False
# MSSQL_SA_PASSWORD=Your_password123!
