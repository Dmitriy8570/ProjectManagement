@model CreateProjectViewModel
@{
    ViewData["Title"] = "New Project";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Projects</a></li>
        <li class="breadcrumb-item active">New Project</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-8">

        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <strong>Please fix the following errors:</strong>
                <ul class="mb-0 mt-1">
                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                    {
                        <li>@error.ErrorMessage</li>
                    }
                </ul>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card">
            <div class="card-header">
                <i class="bi bi-plus-circle me-2"></i>Create New Project
            </div>
            <div class="card-body">

                <!-- Step progress indicators -->
                <div class="wizard-steps mb-4">
                    <div class="wizard-step active" data-step="1">
                        <span class="step-number">1</span>
                        <span class="d-none d-sm-inline">Basic Info</span>
                    </div>
                    <div class="wizard-step" data-step="2">
                        <span class="step-number">2</span>
                        <span class="d-none d-sm-inline">Companies</span>
                    </div>
                    <div class="wizard-step" data-step="3">
                        <span class="step-number">3</span>
                        <span class="d-none d-sm-inline">Manager</span>
                    </div>
                    <div class="wizard-step" data-step="4">
                        <span class="step-number">4</span>
                        <span class="d-none d-sm-inline">Team</span>
                    </div>
                    <div class="wizard-step" data-step="5">
                        <span class="step-number">5</span>
                        <span class="d-none d-sm-inline">Documents</span>
                    </div>
                </div>

                <form id="wizard-form" asp-action="Create" method="post">

                    <!-- ── Step 1: Basic Info ───────────────────────────────── -->
                    <div class="wizard-panel active" data-panel="1">
                        <h5 class="mb-3 text-muted">Step 1 — Project Information</h5>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control" id="Name"
                                   placeholder="e.g. CRM Integration Phase 2" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label"></label>
                                <input asp-for="StartDate" type="date" class="form-control" id="StartDate"
                                       value="@Model.StartDate.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="StartDate" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label"></label>
                                <input asp-for="EndDate" type="date" class="form-control" id="EndDate"
                                       value="@Model.EndDate.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="EndDate" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="mb-3" style="max-width: 180px;">
                            <label asp-for="Priority" class="form-label"></label>
                            <input asp-for="Priority" type="number" min="0" class="form-control" id="Priority" />
                            <div class="form-text">Higher number = higher priority.</div>
                            <span asp-validation-for="Priority" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- ── Step 2: Companies ───────────────────────────────── -->
                    <div class="wizard-panel" data-panel="2">
                        <h5 class="mb-3 text-muted">Step 2 — Companies</h5>
                        <div class="mb-3">
                            <label asp-for="CustomerCompany" class="form-label"></label>
                            <input asp-for="CustomerCompany" class="form-control" id="CustomerCompany"
                                   placeholder="e.g. Acme Corporation" />
                            <span asp-validation-for="CustomerCompany" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ExecutingCompany" class="form-label"></label>
                            <input asp-for="ExecutingCompany" class="form-control" id="ExecutingCompany"
                                   placeholder="e.g. Dev Studio LLC" />
                            <span asp-validation-for="ExecutingCompany" class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- ── Step 3: Project Manager ─────────────────────────── -->
                    <div class="wizard-panel" data-panel="3">
                        <h5 class="mb-3 text-muted">Step 3 — Project Manager</h5>
                        <p class="text-muted small">
                            Search for an employee to assign as the project manager.
                        </p>
                        <div class="mb-3">
                            <label class="form-label">Search Employee</label>
                            <div class="autocomplete-wrapper">
                                <input type="text" id="pm-search" class="form-control"
                                       placeholder="Start typing a name…" autocomplete="off"
                                       value="@Model.ProjectManagerName" />
                                <div id="pm-dropdown" class="autocomplete-dropdown"></div>
                            </div>
                            <input asp-for="ProjectManagerId" type="hidden" id="pm-id" />
                            <span asp-validation-for="ProjectManagerId" class="text-danger small"></span>
                        </div>
                        <div id="pm-selected" class="mt-2" @(Model.ProjectManagerId > 0 ? "" : "style=\"display:none;\"")>
                            <div class="alert alert-info d-flex justify-content-between align-items-center py-2">
                                <span><i class="bi bi-person-badge me-2"></i><strong id="pm-name">@Model.ProjectManagerName</strong></span>
                                <button type="button" class="btn btn-sm btn-outline-secondary" id="pm-clear">
                                    Change
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- ── Step 4: Team Members ────────────────────────────── -->
                    <div class="wizard-panel" data-panel="4">
                        <h5 class="mb-3 text-muted">Step 4 — Team Members</h5>
                        <p class="text-muted small">
                            Optionally add team members. Employees can also be assigned later.
                        </p>
                        <div class="mb-3">
                            <label class="form-label">Search &amp; Add Employee</label>
                            <div class="autocomplete-wrapper">
                                <input type="text" id="emp-search" class="form-control"
                                       placeholder="Start typing a name…" autocomplete="off" />
                                <div id="emp-dropdown" class="autocomplete-dropdown"></div>
                            </div>
                        </div>

                        <div id="emp-chips" class="mb-2">
                            @for (var i = 0; i < Model.EmployeeIds.Count; i++)
                            {
                                <span class="employee-chip" data-id="@Model.EmployeeIds[i]">
                                    @(i < Model.EmployeeNames.Count ? Model.EmployeeNames[i] : $"Employee #{Model.EmployeeIds[i]}")
                                    <button type="button" class="remove-btn" aria-label="Remove">
                                        <i class="bi bi-x"></i>
                                    </button>
                                </span>
                            }
                        </div>

                        <div id="emp-hidden-inputs">
                            @for (var i = 0; i < Model.EmployeeIds.Count; i++)
                            {
                                <input type="hidden" name="EmployeeIds" value="@Model.EmployeeIds[i]" />
                            }
                        </div>

                        <p class="text-muted small" id="emp-empty-hint"
                           @(Model.EmployeeIds.Any() ? "style=\"display:none;\"" : "")>
                            No team members selected yet.
                        </p>
                    </div>

                    <!-- ── Step 5: Documents (stub) ────────────────────────── -->
                    <div class="wizard-panel" data-panel="5">
                        <h5 class="mb-3 text-muted">Step 5 — Project Documents</h5>
                        <p class="text-muted small">
                            Upload supporting documents for the project.
                        </p>

                        <div class="drop-zone" id="drop-zone">
                            <i class="bi bi-cloud-upload"></i>
                            <p class="mb-1">
                                Drag &amp; drop files here, or
                                <label for="file-input" class="drop-zone-link">browse</label>
                            </p>
                            <p class="small text-muted mb-0">
                                File upload will be available in a future release.
                            </p>
                            <input type="file" id="file-input" multiple
                                   style="display:none;" disabled />
                        </div>

                        <div id="file-list" class="mt-3"></div>

                        <div class="alert alert-secondary mt-3 py-2 small">
                            <i class="bi bi-info-circle me-1"></i>
                            You can submit the project now and upload documents later.
                        </div>
                    </div>

                    <!-- ── Navigation ─────────────────────────────────────── -->
                    <div class="d-flex justify-content-between mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-outline-secondary" id="prev-btn"
                                style="display:none;">
                            <i class="bi bi-chevron-left me-1"></i>Previous
                        </button>
                        <div class="ms-auto d-flex gap-2">
                            <button type="button" class="btn btn-primary" id="next-btn">
                                Next<i class="bi bi-chevron-right ms-1"></i>
                            </button>
                            <button type="submit" class="btn btn-success" id="submit-btn"
                                    style="display:none;">
                                <i class="bi bi-check-lg me-1"></i>Create Project
                            </button>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/employee-autocomplete.js" asp-append-version="true"></script>
    <script src="~/js/wizard.js" asp-append-version="true"></script>
    <script>
        initWizard({
            totalSteps: 5,
            validateStep: function (step) {
                if (step === 1) {
                    const name = document.getElementById('Name').value.trim();
                    const start = document.getElementById('StartDate').value;
                    const end = document.getElementById('EndDate').value;
                    const priority = parseInt(document.getElementById('Priority').value, 10);
                    if (!name)  { showStepError('Project name is required.'); return false; }
                    if (!start) { showStepError('Start date is required.'); return false; }
                    if (!end)   { showStepError('End date is required.'); return false; }
                    if (new Date(end) <= new Date(start)) {
                        showStepError('End date must be after start date.'); return false;
                    }
                    if (isNaN(priority) || priority < 0) {
                        showStepError('Priority must be 0 or greater.'); return false;
                    }
                    return true;
                }
                if (step === 2) {
                    const customer = document.getElementById('CustomerCompany').value.trim();
                    const executor = document.getElementById('ExecutingCompany').value.trim();
                    if (!customer) { showStepError('Customer company is required.'); return false; }
                    if (!executor) { showStepError('Executing company is required.'); return false; }
                    return true;
                }
                if (step === 3) {
                    const pmId = document.getElementById('pm-id').value;
                    if (!pmId || pmId === '0') {
                        showStepError('Please select a project manager.'); return false;
                    }
                    return true;
                }
                return true;
            }
        });

        // Project Manager autocomplete (single selection)
        initSingleAutocomplete({
            searchInput: document.getElementById('pm-search'),
            dropdown: document.getElementById('pm-dropdown'),
            hiddenInput: document.getElementById('pm-id'),
            selectedDisplay: document.getElementById('pm-selected'),
            selectedName: document.getElementById('pm-name'),
            clearBtn: document.getElementById('pm-clear'),
            searchUrl: '/employees/search',
            initialId: @Model.ProjectManagerId,
            initialName: '@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ProjectManagerName ?? "").Trim('"'))'
        });

        // Team Members autocomplete (multi-selection)
        initMultiAutocomplete({
            searchInput: document.getElementById('emp-search'),
            dropdown: document.getElementById('emp-dropdown'),
            chipsContainer: document.getElementById('emp-chips'),
            hiddenContainer: document.getElementById('emp-hidden-inputs'),
            emptyHint: document.getElementById('emp-empty-hint'),
            searchUrl: '/employees/search',
            hiddenInputName: 'EmployeeIds',
            excludeInputId: 'pm-id'
        });

        // File drop-zone (stub: visual feedback only, no upload)
        initDropZoneStub(document.getElementById('drop-zone'));
    </script>
}
