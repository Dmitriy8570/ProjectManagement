@model IReadOnlyList<EmployeeDto>
@{
    ViewData["Title"] = "Employees";
    var term = ViewBag.Term as string;
}

<div class="pm-page-header">
    <h2><i class="bi bi-people"></i>Employees</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Add Employee
    </a>
</div>

<div class="d-flex gap-2 mb-4 flex-wrap">
    <div class="autocomplete-wrapper flex-grow-1" style="max-width:380px;">
        <input type="text" id="emp-page-search" class="form-control"
               placeholder="Search by name or email…" autocomplete="off"
               value="@term" />
        <div id="emp-page-dropdown" class="autocomplete-dropdown"></div>
    </div>
    @if (!string.IsNullOrEmpty(term))
    {
        <a asp-action="Index" class="btn btn-outline-secondary" title="Clear search">
            <i class="bi bi-x-circle me-1"></i>Clear
        </a>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-x" style="font-size:3rem;"></i>
        <p class="mt-2">
            @if (!string.IsNullOrEmpty(term))
            {
                <span>No employees found for "<strong>@term</strong>". </span>
                <a asp-action="Index">Show all</a>
            }
            else
            {
                <span>No employees yet. <a asp-action="Create">Add one?</a></span>
            }
        </p>
    </div>
}
else
{
    <p class="text-muted small mb-2">Showing @Model.Count employee(s)</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var emp in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="card-title mb-1">
                            <a asp-action="Detail" asp-route-id="@emp.Id"
                               class="text-decoration-none">
                                <i class="bi bi-person-circle me-1 text-muted"></i>@emp.FullName
                            </a>
                        </h6>
                        <p class="card-text small text-muted mb-0">
                            <i class="bi bi-envelope me-1"></i>@emp.Email
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-1 bg-transparent border-top-0 pb-2 pt-0">
                        <a asp-action="Edit" asp-route-id="@emp.Id"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@emp.Id" method="post" class="ms-auto"
                              onsubmit="return confirm('Delete @emp.FullName? This cannot be undone.')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <script src="~/js/employee-autocomplete.js" asp-append-version="true"></script>
    <script>
        initEmployeePageSearch({
            searchInput: document.getElementById('emp-page-search'),
            dropdown:    document.getElementById('emp-page-dropdown'),
            searchUrl:   '/employees/search'
        });
    </script>
}
