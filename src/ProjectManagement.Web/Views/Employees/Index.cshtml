@model IReadOnlyList<EmployeeDto>
@{
    ViewData["Title"] = "Employees";
    var term = ViewBag.Term as string;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0"><i class="bi bi-people me-2"></i>Employees</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Add Employee
    </a>
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="search" name="term" class="form-control form-control-sm"
                   placeholder="Search by name or email…" value="@term" style="max-width:300px;" />
            <button type="submit" class="btn btn-sm btn-outline-primary">
                <i class="bi bi-search"></i>
            </button>
            @if (!string.IsNullOrEmpty(term))
            {
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-x-circle"></i>
                </a>
            }
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-x" style="font-size:3rem;"></i>
        <p class="mt-2">
            @if (!string.IsNullOrEmpty(term))
            {
                <span>No employees found for "<strong>@term</strong>". </span>
                <a asp-action="Index">Show all</a>
            }
            else
            {
                <span>No employees yet. <a asp-action="Create">Add one?</a></span>
            }
        </p>
    </div>
}
else
{
    <p class="text-muted small mb-2">@Model.Count employee(s)</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var emp in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h6 class="card-title mb-1">
                            <a asp-action="Detail" asp-route-id="@emp.Id"
                               class="text-decoration-none">
                                <i class="bi bi-person-circle me-1 text-muted"></i>@emp.FullName
                            </a>
                        </h6>
                        <p class="card-text small text-muted mb-0">
                            <i class="bi bi-envelope me-1"></i>@emp.Email
                        </p>
                    </div>
                    <div class="card-footer d-flex gap-1 bg-transparent border-top-0 pb-2 pt-0">
                        <a asp-action="Detail" asp-route-id="@emp.Id"
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a asp-action="Edit" asp-route-id="@emp.Id"
                           class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Delete" asp-route-id="@emp.Id" method="post" class="ms-auto"
                              onsubmit="return confirm('Delete @emp.FullName? This cannot be undone.')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
